# Ghostty modern macOS baseline
# Managed by chezmoi. Reload inside Ghostty with Cmd+Shift+,.

# Appearance: keep the current kitty/Catppuccin look, but use Ghostty's built-in theme.
theme = Catppuccin Mocha
font-family = JetBrainsMono Nerd Font
font-size = 14
background-opacity = 0.92
background-opacity-cells = true
background-blur = 20
window-padding-x = 8
window-padding-y = 8
window-padding-balance = true
window-padding-color = background
macos-titlebar-style = hidden
macos-titlebar-proxy-icon = hidden
window-save-state = always
window-width = 120
window-height = 36

# Cursor and interaction.
cursor-style = bar
cursor-style-blink = true
mouse-hide-while-typing = true
copy-on-select = false
right-click-action = copy-or-paste
confirm-close-surface = true
scrollback-limit = 100000000

# Clipboard / OSC 52. Keep writes open for tmux/SSH/nvim copy; ask before terminal apps read.
clipboard-read = ask
clipboard-write = allow
clipboard-paste-protection = true
clipboard-paste-bracketed-safe = true
clipboard-trim-trailing-spaces = true

# Shell integration for zsh: cwd-aware tabs/splits, prompt jumping, better resizing.
shell-integration = zsh
shell-integration-features = cursor,title,ssh-env,ssh-terminfo,path,no-sudo

# macOS Option should behave as terminal Alt for tmux, Neovim, and shell tools.
macos-option-as-alt = true

# Quick terminal: lightweight scratch terminal while Ghostty is focused.
# Avoid global keybinds on Ghostty 1.3.1/macOS 15 because CLI config validation can crash
# while registering AppKit global shortcuts.
quick-terminal-position = top
quick-terminal-size = 45%
quick-terminal-screen = mouse
quick-terminal-animation-duration = 0.12
quick-terminal-autohide = true
quick-terminal-space-behavior = move
keybind = cmd+backquote=toggle_quick_terminal

# Preserve terminal app Alt+Arrow navigation for tmux and Neovim.
keybind = alt+arrow_left=unbind
keybind = alt+arrow_right=unbind

# Ergonomic split workflow that mirrors the tmux/vim direction model.
keybind = super+d=new_split:right
keybind = super+shift+d=new_split:down
keybind = super+alt+h=goto_split:left
keybind = super+alt+j=goto_split:down
keybind = super+alt+k=goto_split:up
keybind = super+alt+l=goto_split:right
keybind = super+ctrl+h=resize_split:left,10
keybind = super+ctrl+j=resize_split:down,10
keybind = super+ctrl+k=resize_split:up,10
keybind = super+ctrl+l=resize_split:right,10
keybind = super+shift+enter=toggle_split_zoom

# Prompt-aware navigation requires shell integration.
keybind = super+arrow_up=jump_to_prompt:-1
keybind = super+arrow_down=jump_to_prompt:1

# Housekeeping.
keybind = super+,=open_config
keybind = super+shift+,=reload_config
keybind = super+shift+p=toggle_command_palette
keybind = super+shift+o=toggle_background_opacity
